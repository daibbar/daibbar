<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="daibbar — a refined reading experience for ideas that matter.">
    <title>daibbar — Stories, refined.</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <header class="nav">
        <div class="nav__inner">
            <a href="/" class="nav__logo">daibbar<span>.</span></a>
            <nav aria-label="Primary">
                <ul class="nav__links">
                    <li><a href="/articles">Articles</a></li>
                    <li><a href="/About">About</a></li>
                    <li><a href="/Projects">Projects</a></li>
                </ul>
            </nav>
            <a href="/articles" class="btn btn--ghost btn--sm">Contact me</a>
        </div>
    </header>

    <main>
        <section class="hero">
            <p class="eyebrow">daibbar official website!</p>
            <h1 class="hero__title">Just<br>Learn.</h1>
            <p class="hero__sub">Learn, build, document, and share.</p>
            <div class="hero__ctas">
                <a href="/articles" class="btn btn--primary">Read articles</a>
                <a href="#features" class="btn btn--link">Learn more <span aria-hidden="true">›</span></a>
            </div>
            <div class="hero__glow" aria-hidden="true"></div>
        </section>

        <section class="features" id="features">
            <h2 class="section__title">Designed for focus.</h2>
            <p class="section__sub">Every detail considered. Nothing in the way.</p>
            <div class="features__grid">
                <article class="feature-card">
                    <div class="feature-card__dot"></div>
                    <h3>Effortless reading</h3>
                    <p>Typography crafted for clarity at every size, on every screen.</p>
                </article>
                <article class="feature-card">
                    <div class="feature-card__dot"></div>
                    <h3>Beautifully minimal</h3>
                    <p>A canvas that fades away so the words can lead the way.</p>
                </article>
                <article class="feature-card">
                    <div class="feature-card__dot"></div>
                    <h3>Built for speed</h3>
                    <p>Lightweight, responsive, and quietly powerful from the first byte.</p>
                </article>
            </div>
        </section>

        <section class="showcase" id="showcase">
            <div class="showcase__glow" aria-hidden="true"></div>
            <div class="showcase__inner">
                <p class="eyebrow eyebrow--light">Crafted with intent</p>
                <h2 class="showcase__title">Where words<br>feel <span>premium</span>.</h2>
                <p class="showcase__sub">A platform that treats every article like it deserves the spotlight — because it does.</p>
                <a href="/articles" class="btn btn--red">Explore the library</a>
            </div>
        </section>

        <section class="cta">
            <h2 class="cta__title">Ready to dive in?</h2>
            <p class="cta__sub">The good stuff is just one click away.</p>
            <a href="/articles" class="btn btn--primary">Browse articles</a>
        </section>
    </main>

    <footer class="footer">
        <div class="footer__inner">
            <a href="/" class="footer__brand">daibbar<span>.</span></a>
            <p class="footer__copy">&copy; 2026 daibbar. Crafted with care.</p>
        </div>
    </footer>
</body>
</html>
